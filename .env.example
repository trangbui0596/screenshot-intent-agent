# Get your Anthropic API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Get your Notion integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_...

# The Notion page ID where to-do items will be created
# (Open the page in Notion, copy the URL — the ID is the 32-char hex string at the end)
NOTION_PAGE_ID=your-page-id-here

# Folder containing your iPhone screenshots (iCloud Photos path on your Windows)
SCREENSHOTS_FOLDER=C:/Users/Trang Bui/iCloudPhotos/Photos
